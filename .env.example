# Optional override for the lead-intake Function URL.
# In normal operation the URL is read from amplify_outputs.json after
# `npx ampx sandbox` or an Amplify Hosting deploy. Use this only if you
# need to point the form at a different deployed function.
# VITE_LEAD_INTAKE_URL=https://xxxxxxxxxxxx.lambda-url.us-east-1.on.aws/
